---
import BaseLayout from '../layouts/BaseLayout.astro';
import Arrow from '../components/Arrow.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'mama-osa');
if (!page) throw new Error('Missing src/content/pages/mama-osa.md');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <header class="mama-hero">
    <div class="container mama-grid">
      <div>
        <p class="eyebrow">{page.data.eyebrow}</p>
        <h1>{page.data.heading}</h1>
        <p class="lead">{page.data.lead}</p>
      </div>
      <div class="cave" aria-hidden="true"><span></span><i></i><b></b></div>
    </div>
  </header>

  <section class="story-section">
    <div class="container story-grid">
      <div class="story-index"><span>01</span><p>La historia</p></div>
      <div class="reading-width">
        <Content />
      </div>
    </div>
  </section>

  <section class="recognition-section">
    <div class="container recognition-grid">
      <p class="eyebrow">{page.data.recognitionLabel}</p>
      <blockquote>“{page.data.recognition}”</blockquote>
      <p>{page.data.recognitionDescription}</p>
    </div>
  </section>

  <section class="section episodes-section">
    <div class="container">
      <div class="section-rule"><div><p class="eyebrow">Archivo sonoro</p><h2>Episodios seleccionados</h2></div></div>
      <div class="episode-feature">
        <div class="play" aria-hidden="true">▶</div>
        <div>
          <h3>{page.data.episodesTitle}</h3>
          <p>{page.data.episodesDescription}</p>
        </div>
      </div>
      <a class="archive-link" href={page.data.archiveUrl} rel="external">Visitar el archivo de Radio Nacional <Arrow /></a>
    </div>
  </section>
</BaseLayout>

<style>
  .mama-hero { padding-block: clamp(5rem, 12vw, 10rem); color: var(--cream); background: var(--moss-dark); overflow: hidden; }
  .mama-grid { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr); gap: 4rem; align-items: center; }
  .mama-hero .eyebrow, .mama-hero .lead { color: rgba(250,247,240,0.7); }
  .mama-hero h1 { max-width: 8ch; }
  .mama-hero .lead { max-width: 35ch; margin-top: 2rem; }
  .cave { position: relative; aspect-ratio: 1; border: 1px solid rgba(250,247,240,0.3); border-radius: 50% 50% 44% 44%; }
  .cave::before { position: absolute; inset: 18%; border-radius: 50% 50% 44% 44%; background: var(--ink); content: ''; }
  .cave span, .cave i, .cave b { position: absolute; display: block; border-radius: 50%; background: var(--ochre); }
  .cave span { width: 8%; aspect-ratio: 1; top: 20%; left: 19%; }
  .cave i { width: 4%; aspect-ratio: 1; top: 10%; right: 32%; }
  .cave b { width: 5%; aspect-ratio: 1; bottom: 18%; right: 11%; }
  .story-section { padding-block: clamp(5rem, 11vw, 9rem); background: var(--cream); }
  .story-grid { display: grid; grid-template-columns: minmax(140px, 0.35fr) minmax(0, 1.65fr); gap: clamp(2rem, 7vw, 6rem); }
  .story-index span { color: var(--terracotta); font-family: var(--serif); font-size: 3rem; }
  .story-index p { color: var(--ink-soft); }
  .story-grid :global(p:first-child) { color: var(--ink); font-family: var(--serif); font-size: clamp(1.25rem, 2vw, 1.6rem); line-height: 1.4; }
  .story-grid :global(p) { margin-bottom: 1.5rem; }
  .recognition-section { padding-block: clamp(4rem, 10vw, 8rem); background: var(--ochre); }
  .recognition-grid { display: grid; grid-template-columns: 0.4fr 1.2fr 0.6fr; gap: clamp(2rem, 6vw, 5rem); align-items: end; }
  blockquote { margin: 0; font-family: var(--serif); font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.98; letter-spacing: -0.04em; }
  .recognition-grid > p:last-child { max-width: 33ch; margin: 0; }
  .episode-feature { display: grid; grid-template-columns: 80px 1fr; gap: 1.5rem; align-items: center; max-width: 800px; padding: 2rem 0; border-block: 1px solid var(--line); }
  .play { display: grid; place-items: center; width: 70px; aspect-ratio: 1; border: 1px solid var(--ink); border-radius: 50%; }
  .episode-feature h3 { margin-bottom: 0.5rem; }
  .episode-feature p { margin: 0; color: var(--ink-soft); }
  .archive-link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 2rem; }
  .archive-link :global(svg) { width: 1rem; }
  @media (max-width: 760px) {
    .mama-grid, .story-grid, .recognition-grid { grid-template-columns: 1fr; }
    .cave { max-width: 320px; }
    .episode-feature { grid-template-columns: 1fr; }
  }
</style>
