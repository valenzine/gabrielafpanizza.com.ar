---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada">
  <section class="not-found container">
    <div><p class="eyebrow">Error 404</p><h1>Esta rama no creció.</h1><p class="lead">La página que buscás no existe o cambió de dirección.</p><a class="button-link" href="/">Volver al inicio</a></div>
    <img class="botanical" src="/assets/manzana-portada.png" alt="" />
  </section>
</BaseLayout>

<style>
  .not-found { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 4rem; align-items: end; padding-block: clamp(5rem, 14vw, 12rem); }
  .not-found h1 { max-width: 8ch; }
  .not-found .lead { max-width: 30ch; margin-block: 2rem; }
  .botanical { width: 100%; max-width: 360px; mix-blend-mode: multiply; }
  @media (max-width: 680px) { .not-found { grid-template-columns: 1fr; } }
</style>
