---
import type { Book } from '../lib/books';

interface Props { book: Book; compact?: boolean; }
const { book, compact = false } = Astro.props;
---

<div class:list={['book-cover', `tone-${book.coverTone}`, { compact, photographic: Boolean(book.cover) }]}>
  {book.cover ? (
    <img src={book.cover} alt={`Tapa de ${book.title}`} loading="lazy" />
  ) : (
    <>
      <span class="cover-publisher">{book.publisher}</span>
      <span class="cover-title">{book.title}</span>
      <span class="cover-author">Gabriela Fernández Panizza</span>
      <span class="cover-year">{book.year}</span>
    </>
  )}
</div>

<style>
  .book-cover {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    aspect-ratio: 0.72;
    min-height: 0;
    padding: clamp(1rem, 2.5vw, 1.6rem);
    overflow: hidden;
    color: var(--cream);
    background: var(--moss);
    box-shadow: 0 16px 36px rgba(37, 39, 34, 0.13);
  }
  .book-cover::after {
    position: absolute;
    right: -16%;
    bottom: -7%;
    width: 75%;
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    opacity: 0.2;
    content: '';
  }
  .tone-ochre { color: var(--ink); background: var(--ochre); }
  .tone-terracotta { background: var(--terracotta); }
  .tone-blue { background: #536d78; }
  .tone-paper { color: var(--ink); background: var(--paper-deep); }
  .cover-publisher, .cover-author { position: relative; z-index: 1; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; }
  .cover-title { position: relative; z-index: 1; font-family: var(--serif); font-size: clamp(1.4rem, 3vw, 2.2rem); line-height: 0.96; }
  .cover-year { position: absolute; right: 1rem; bottom: 0.5rem; font-family: var(--serif); font-size: clamp(3rem, 7vw, 5rem); line-height: 1; opacity: 0.13; }
  .photographic { padding: 0; background: var(--paper-deep); }
  .photographic::after { content: none; }
  .photographic img { width: 100%; height: 100%; object-fit: cover; }
  .compact .cover-title { font-size: clamp(1.2rem, 2.4vw, 1.75rem); }
</style>
